[gd_scene format=3 uid="uid://blo0vfud4jdt0"]

[sub_resource type="GDScript" id="GDScript_und3l"]
script/source = "extends Node

const HOUSE_SCENE_PATH: String = \"res://scenes/test_house_scene.tscn\"

signal house_ready

@onready var _loading_screen: CanvasLayer = $LoadingScreen
@onready var _loading_screen_animator: AnimationPlayer = $LoadingScreen/AnimationPlayer

func _ready() -> void:
	_loading_screen.visible = true
	_loading_screen_animator.play(\"loading\")
	call_deferred(\"_create_house\")
	await house_ready
	_loading_screen.visible = false
	_loading_screen_animator.stop()
	
func _create_house() -> void:
	ResourceLoader.load_threaded_request(HOUSE_SCENE_PATH)
	while(ResourceLoader.load_threaded_get_status(HOUSE_SCENE_PATH) != ResourceLoader.ThreadLoadStatus.THREAD_LOAD_LOADED):
		await get_tree().create_timer(0.001).timeout
	var house_scene: PackedScene = ResourceLoader.load_threaded_get(HOUSE_SCENE_PATH)
	var house = house_scene.instantiate()
	add_child(house)
	house_ready.emit()
"

